{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "scripts": {
    "predev": "bun run --cwd packages/types build && bun run sync:types",
    "sync:types": "rsync -a packages/types/dist/ node_modules/@fxprime/types/dist/",
    "dev": "bun --watch src/index.ts",
    "build": "bunx prisma generate && bun run --cwd packages/types build && bun run sync:types && bunx tsc",
    "start": "bun dist/index.js",
    "db:migrate": "bunx prisma migrate dev",
    "db:seed": "bun prisma/seed.ts",
    "db:backfill-student-ids": "bun scripts/backfill-student-ids.ts",
    "db:seed-institutional-reviews": "bun scripts/seed-institutional-reviews.ts",
    "db:studio": "bunx prisma studio",
    "db:generate": "bunx prisma generate",
    "test": "bun test tests/",
    "postinstall": "bunx prisma generate && bun run --cwd packages/types build && bun run sync:types"
  },
  "dependencies": {
    "@fxprime/types": "file:./packages/types",
    "@prisma/client": "^6.8.2",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.19.1",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.35.1",
    "socket.io": "^4.8.3",
    "uuid": "^11.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.8.2",
    "typescript": "5.7.3"
  }
}
