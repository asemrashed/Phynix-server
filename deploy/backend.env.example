# Copy to /var/www/fxprime/backend.env on the VPS and fill real secrets.
# Keep this file out of GitHub secrets; production secrets live only on the VPS.

NODE_ENV=production
PORT=4005

# Host PostgreSQL is kept outside Docker. Docker resolves this gateway host via compose extra_hosts.
DATABASE_URL=postgresql://user:password@host.docker.internal:5432/fxprime
REDIS_URL=redis://redis:6379

JWT_SECRET=change-me-min-32-characters-long-secret
JWT_REFRESH_SECRET=change-me-min-32-characters-refresh-secret
JWT_ACCESS_EXPIRY=3d
JWT_REFRESH_EXPIRY_DAYS=7

FRONTEND_URL=https://learning.phynixeducation.com
PUBLIC_SITE_URL=https://learning.phynixeducation.com
API_PUBLIC_URL=https://api.phynixeducation.com/api/v1
CORS_ORIGINS=https://learning.phynixeducation.com

STORAGE_PROVIDER=local
REQUIRE_EMAIL_VERIFICATION=true
RESEND_API_KEY=
EMAIL_FROM=FX Prime Academy <noreply@phynixeducation.com>

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_IS_SANDBOX=true

SSLCOMMERZ_STORE_ID=testbox
SSLCOMMERZ_STORE_PASSWD=qwerty
SSLCOMMERZ_IS_SANDBOX=true
