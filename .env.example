# ─── Local development (copy to .env) ───────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/fxprime

JWT_SECRET=change-me-min-32-characters-long-secret
JWT_REFRESH_SECRET=change-me-min-32-characters-refresh-secret
# Access token lifetime (JWT sent to frontend) — e.g. 15m, 1h, 3d
JWT_ACCESS_EXPIRY=3d
# Refresh token / session cookie lifetime in days
JWT_REFRESH_EXPIRY_DAYS=7

PORT=4000
FRONTEND_URL=http://localhost:3000
# Public URL embedded in certificate QR codes
PUBLIC_SITE_URL=http://localhost:3000
# Comma-separated extra CORS origins (FRONTEND_URL is always included)
CORS_ORIGINS=
API_PUBLIC_URL=http://localhost:4000/api/v1
NODE_ENV=development

# ─── Production example ─────────────────────────────────────────────
# FRONTEND_URL=https://learning.phynixeducation.com
# PUBLIC_SITE_URL=https://learning.phynixeducation.com
# CORS_ORIGINS=
# API_PUBLIC_URL=https://api.phynixeducation.com/api/v1
# NODE_ENV=production

# File storage — local (dev) or s3 (production)
STORAGE_PROVIDER=local
# S3_BUCKET=phynix-uploads
# S3_PUBLIC_URL=https://cdn.phynixeducation.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-1

# Rate limits (requests per minute per IP)
PAYMENT_RATE_LIMIT_MAX=20
WEBHOOK_RATE_LIMIT_MAX=60

# Block enroll/payment/subscribe until email verified
REQUIRE_EMAIL_VERIFICATION=true

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Phynix Education <noreply@phynixeducation.com>
EMAIL_PROVIDER=resend

# Gmail SMTP (set EMAIL_PROVIDER=gmail to use SMTP)
# Use a Gmail App Password (not your regular Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# SSLCommerz (default payment gateway — sandbox credentials for testing)
SSLCOMMERZ_STORE_ID=testbox
SSLCOMMERZ_STORE_PASSWD=qwerty
SSLCOMMERZ_IS_SANDBOX=true
USD_TO_BDT_RATE=110

# Skip 1-device-per-type login limit (dev only — set true to allow multiple sessions)
SKIP_DEVICE_LIMIT=false

# Order cleanup — cancel unpaid orders after N hours
ORDER_CLEANUP_HOURS=24
ORDER_CLEANUP_INTERVAL_MS=3600000

# Subscription lifecycle — grace period & cron interval
SUBSCRIPTION_GRACE_DAYS=3
SUBSCRIPTION_LIFECYCLE_INTERVAL_MS=3600000

# Blog — auto-publish scheduled posts
BLOG_PUBLISH_INTERVAL_MS=60000

# Live sessions — paste Zoom/Google Meet link on each session (no auto-provisioning)
MEETING_TIMEZONE=Asia/Dhaka

# Mentor bookings — cancel/reschedule window & reminder cron
MENTOR_CANCEL_HOURS=24
MENTOR_REMINDER_INTERVAL_MS=900000
